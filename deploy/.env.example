# Copy this file to deploy/.env and fill in real values from local Hub/CLAUDE.md → СЕКРЕТЫ.
# deploy/.env is gitignored — never commit it.

SERVER_HOST=94.241.168.8
SERVER_USER=root

# Основной путь — ssh-ключ (генерация: ssh-keygen -t ed25519 -f ~/.ssh/signaris_hub_deploy;
# публичный ключ добавить в /root/.ssh/authorized_keys на VPS).
SSH_KEY=~/.ssh/signaris_hub_deploy

# Fallback, если ключ не настроен (пароль из CLAUDE.md → СЕКРЕТЫ).
SERVER_PASS=<paste from CLAUDE.md СЕКРЕТЫ — VPS root password>
