[Unit]
Description=Signaris Hub backend (staging)
After=network.target postgresql.service redis-server.service

[Service]
Type=exec
User=signaris
Group=signaris
WorkingDirectory=/opt/signaris-hub-staging
EnvironmentFile=/opt/signaris-hub-staging/.env
ExecStart=/opt/signaris-hub-staging/.venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 5060 --workers 1
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
